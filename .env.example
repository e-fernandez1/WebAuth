# Copy this file to .env and fill in your values.
# .env is gitignored, .env.example is checked in.

# Flask secret (any long random string)
SECRET_KEY=replace-with-a-long-random-string

# SMTP for email-based 2FA.
# Leave SMTP_HOST blank to use console fallback (codes printed in PowerShell).
#
# Gmail setup:
#   1. Enable 2-Step Verification on your Google account.
#   2. Visit https://myaccount.google.com/apppasswords and create an App Password
#      (you must have 2-Step Verification enabled to see this option).
#   3. Use the 16-character password Google generates as SMTP_PASSWORD below.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=WebAuth Demo <your.email@gmail.com>
